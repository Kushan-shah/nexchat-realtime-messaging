# Server Setup
PORT=3000
NODE_ENV=development

# Database (Prisma)
# For production PostgreSQL: DATABASE_URL="postgresql://user:pass@host:5432/chatdb"
# For local development with SQLite (default):
DATABASE_URL="file:./dev.db"

# Redis (real Redis is the default — install Redis or use Docker)
REDIS_URL="redis://localhost:6379"
# For zero-dependency local dev without Redis: REDIS_URL="memory"

# Security / JWT
JWT_SECRET="super-secret-jwt-key-replace-in-production"
JWT_EXPIRES_IN="1d"

# OpenAI (optional — uncomment and set a real key to enable AI smart replies)
# OPENAI_API_KEY="sk-your-real-openai-key"
GEMINI_API_KEYS="key1,key2,key3"
AI_TIMEOUT_MS=5000

# Feature Flags
FEATURE_AI_ENABLED=true
FEATURE_RATE_LIMIT=true

# Rate Limits Config
RATE_LIMIT_MSGS_PER_SEC=5
RATE_LIMIT_BURST=20
