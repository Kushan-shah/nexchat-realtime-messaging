{
  "name": "nexchat-realtime-messaging",
  "version": "1.0.0",
  "description": "Production-grade real-time messaging system with Socket.IO, Redis idempotency, sliding window rate limiting, and AI-powered smart replies",
  "main": "src/server.js",
  "keywords": [
    "websocket",
    "real-time",
    "chat",
    "socket.io",
    "redis",
    "rate-limiter",
    "idempotency",
    "nodejs",
    "postgresql",
    "system-design"
  ],
  "scripts": {
    "start": "node src/server.js",
    "dev": "nodemon src/server.js",
    "build": "npx prisma generate && npx prisma migrate deploy",
    "test": "jest",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev"
  },
  "dependencies": {
    "@google/generative-ai": "^0.24.1",
    "@prisma/client": "^5.10.2",
    "bcrypt": "^6.0.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.18.3",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "openai": "^4.28.4",
    "pino": "^8.19.0",
    "redis": "^4.6.13",
    "socket.io": "^4.7.4",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.0",
    "xss": "^1.0.14",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "axios": "^1.14.0",
    "jest": "^29.7.0",
    "node-mocks-http": "^1.14.1",
    "nodemon": "^3.1.0",
    "prisma": "^5.10.2",
    "socket.io-client": "^4.8.3",
    "supertest": "^6.3.4",
    "uuid": "^13.0.0"
  }
}
